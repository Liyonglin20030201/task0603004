generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum CourseStatus {
  active
  archived
  completed
}

enum PlanStatus {
  active
  paused
  completed
  delayed
}

enum PlanItemStatus {
  pending
  completed
  skipped
}

enum NotificationType {
  reminder
  system
  achievement
  group
  goal
}

enum NotificationChannel {
  in_app
  email
  sms
}

enum GoalType {
  long_term
  short_term
}

enum GoalStatus {
  active
  completed
  abandoned
}

enum ReportPeriod {
  monthly
  quarterly
  yearly
}

enum ReportStatus {
  pending
  generating
  completed
  failed
}

enum GroupRole {
  owner
  admin
  member
}

enum GroupJoinPolicy {
  open
  approval
  invite
}

enum PredictionType {
  completion_rate
  study_time
  engagement
  retention
}

enum AlertSeverity {
  info
  warning
  critical
}

enum SmartPlanStatus {
  draft
  active
  completed
  expired
}

enum PartnerRequestStatus {
  pending
  accepted
  rejected
  cancelled
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  nickname     String   @db.VarChar(50)
  phone        String?  @db.VarChar(20)
  avatarUrl    String?  @map("avatar_url")
  role         UserRole @default(user)
  timezone     String   @default("Asia/Shanghai") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  courses                 Course[]
  learningPlans           LearningPlan[]
  checkIns                CheckIn[]
  wrongAnswers            WrongAnswer[]
  notes                   Note[]
  aiReviewSuggestions     AIReviewSuggestion[]
  notifications           Notification[]
  systemConfigUpdates     SystemConfig[]
  resources               Resource[]
  notificationPreferences NotificationPreference[]
  learningGoals           LearningGoal[]
  userBadges              UserBadge[]
  analysisReports         AnalysisReport[]
  ownedGroups             StudyGroup[]    @relation("GroupOwner")
  groupMemberships        GroupMember[]
  groupSharedItems        GroupSharedItem[]
  groupMessages           GroupMessage[]
  learningPredictions     LearningPrediction[]
  learningAlerts          LearningAlert[]
  studyHabitProfile       StudyHabitProfile?
  smartSchedules          SmartSchedule[]
  syncLogs                SyncLog[]
  offlineQueues           OfflineQueue[]
  partnerProfile          PartnerProfile?
  sentPartnerRequests     PartnerRequest[] @relation("SentRequests")
  receivedPartnerRequests PartnerRequest[] @relation("ReceivedRequests")
  partnerships1           Partnership[]    @relation("Partnerships1")
  partnerships2           Partnership[]    @relation("Partnerships2")

  @@map("users")
}

model Course {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  title       String       @db.VarChar(200)
  category    String       @db.VarChar(50)
  description String       @default("")
  status      CourseStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user                User                 @relation(fields: [userId], references: [id])
  learningPlans       LearningPlan[]
  wrongAnswers        WrongAnswer[]
  notes               Note[]
  aiReviewSuggestions AIReviewSuggestion[]
  resources           Resource[]
  learningGoals       LearningGoal[]

  @@index([userId, status])
  @@map("courses")
}

model LearningPlan {
  id              String     @id @default(uuid())
  userId          String     @map("user_id")
  courseId         String     @map("course_id")
  title           String     @db.VarChar(200)
  startDate       DateTime   @map("start_date") @db.Date
  endDate         DateTime   @map("end_date") @db.Date
  status          PlanStatus @default(active)
  originalEndDate DateTime?  @map("original_end_date") @db.Date
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  user     User       @relation(fields: [userId], references: [id])
  course   Course     @relation(fields: [courseId], references: [id])
  items    PlanItem[]
  resources Resource[]
  goal     LearningGoal? @relation("GoalPlans", fields: [goalId], references: [id])
  goalId   String?    @map("goal_id")

  @@index([userId, status])
  @@index([courseId])
  @@map("learning_plans")
}

model PlanItem {
  id            String         @id @default(uuid())
  planId        String         @map("plan_id")
  title         String         @db.VarChar(200)
  scheduledDate DateTime       @map("scheduled_date") @db.Date
  originalDate  DateTime?      @map("original_date") @db.Date
  sortOrder     Int            @default(0) @map("sort_order")
  status        PlanItemStatus @default(pending)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  plan     LearningPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  checkIns CheckIn[]
  notes    Note[]

  @@index([planId, scheduledDate])
  @@index([planId, status])
  @@map("plan_items")
}

model CheckIn {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  planItemId      String   @map("plan_item_id")
  checkInDate     DateTime @map("check_in_date") @db.Date
  durationMinutes Int?     @map("duration_minutes")
  note            String?
  version         Int      @default(1)
  createdAt       DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  planItem PlanItem @relation(fields: [planItemId], references: [id])

  @@unique([userId, planItemId, checkInDate])
  @@index([userId, checkInDate])
  @@map("check_ins")
}

model WrongAnswer {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  courseId        String    @map("course_id")
  question       String
  wrongAnswer    String    @map("wrong_answer")
  correctAnswer  String    @map("correct_answer")
  explanation    String?
  tags           String[]  @default([])
  reviewCount    Int       @default(0) @map("review_count")
  nextReviewDate DateTime? @map("next_review_date") @db.Date
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@index([userId, courseId])
  @@index([userId, nextReviewDate])
  @@map("wrong_answers")
}

model Note {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  courseId    String?  @map("course_id")
  planItemId String?  @map("plan_item_id")
  title      String   @db.VarChar(200)
  content    String   @default("")
  tags       String[] @default([])
  version    Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  course   Course?   @relation(fields: [courseId], references: [id])
  planItem PlanItem? @relation(fields: [planItemId], references: [id])

  @@index([userId, courseId])
  @@map("notes")
}

model AIReviewSuggestion {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  courseId           String?  @map("course_id")
  suggestionContent Json     @map("suggestion_content")
  generatedAt       DateTime @default(now()) @map("generated_at")
  accepted          Boolean  @default(false)

  user   User    @relation(fields: [userId], references: [id])
  course Course? @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@map("ai_review_suggestions")
}

model Notification {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  type         NotificationType @default(system)
  title        String           @db.VarChar(200)
  content      String           @default("")
  read         Boolean          @default(false)
  channel      String           @default("in_app") @db.VarChar(20)
  scheduledFor DateTime?        @map("scheduled_for")
  createdAt    DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([scheduledFor])
  @@map("notifications")
}

model SystemConfig {
  key       String   @id @db.VarChar(100)
  value     Json
  updatedBy String   @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  updater User @relation(fields: [updatedBy], references: [id])

  @@map("system_configs")
}

model Resource {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String   @db.VarChar(200)
  description String   @default("")
  fileName    String   @map("file_name") @db.VarChar(255)
  filePath    String   @map("file_path") @db.VarChar(500)
  fileSize    Int      @map("file_size")
  mimeType    String   @map("mime_type") @db.VarChar(100)
  courseId     String?  @map("course_id")
  planId      String?  @map("plan_id")
  downloads   Int      @default(0)
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User          @relation(fields: [userId], references: [id])
  course Course?       @relation(fields: [courseId], references: [id])
  plan   LearningPlan? @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@index([isPublic])
  @@map("resources")
}

model NotificationPreference {
  id        String              @id @default(uuid())
  userId    String              @map("user_id")
  type      NotificationType
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type, channel])
  @@map("notification_preferences")
}

model LearningGoal {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  title       String     @db.VarChar(200)
  description String     @default("")
  type        GoalType
  status      GoalStatus @default(active)
  targetDate  DateTime?  @map("target_date") @db.Date
  progress    Float      @default(0)
  parentId    String?    @map("parent_id")
  courseId     String?    @map("course_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user     User           @relation(fields: [userId], references: [id])
  parent   LearningGoal?  @relation("GoalHierarchy", fields: [parentId], references: [id])
  children LearningGoal[] @relation("GoalHierarchy")
  course   Course?        @relation(fields: [courseId], references: [id])
  plans    LearningPlan[] @relation("GoalPlans")
  badges   UserBadge[]

  @@index([userId, status])
  @@index([parentId])
  @@map("learning_goals")
}

model Badge {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  description String   @default("")
  icon        String   @default("") @db.VarChar(100)
  condition   Json
  createdAt   DateTime @default(now()) @map("created_at")

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  badgeId  String   @map("badge_id")
  goalId   String?  @map("goal_id")
  earnedAt DateTime @default(now()) @map("earned_at")

  user  User          @relation(fields: [userId], references: [id])
  badge Badge         @relation(fields: [badgeId], references: [id])
  goal  LearningGoal? @relation(fields: [goalId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model AnalysisReport {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  period      ReportPeriod
  periodStart DateTime     @map("period_start") @db.Date
  periodEnd   DateTime     @map("period_end") @db.Date
  status      ReportStatus @default(pending)
  reportData  Json?        @map("report_data")
  aiSummary   String?      @map("ai_summary")
  generatedAt DateTime?    @map("generated_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, period, periodStart])
  @@index([userId])
  @@map("analysis_reports")
}

model StudyGroup {
  id          String          @id @default(uuid())
  name        String          @db.VarChar(100)
  description String          @default("")
  ownerId     String          @map("owner_id")
  joinPolicy  GroupJoinPolicy @default(open) @map("join_policy")
  maxMembers  Int             @default(20) @map("max_members")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  owner       User             @relation("GroupOwner", fields: [ownerId], references: [id])
  members     GroupMember[]
  sharedItems GroupSharedItem[]
  goals       GroupGoal[]
  messages    GroupMessage[]

  @@index([ownerId])
  @@map("study_groups")
}

model GroupMember {
  id       String    @id @default(uuid())
  groupId  String    @map("group_id")
  userId   String    @map("user_id")
  role     GroupRole @default(member)
  joinedAt DateTime  @default(now()) @map("joined_at")

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

model GroupSharedItem {
  id       String   @id @default(uuid())
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  itemType String   @map("item_type") @db.VarChar(20)
  itemId   String   @map("item_id")
  sharedAt DateTime @default(now()) @map("shared_at")

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id])

  @@unique([groupId, itemType, itemId])
  @@index([groupId])
  @@map("group_shared_items")
}

model GroupGoal {
  id          String     @id @default(uuid())
  groupId     String     @map("group_id")
  title       String     @db.VarChar(200)
  description String     @default("")
  targetDate  DateTime?  @map("target_date") @db.Date
  progress    Float      @default(0)
  targetType  String?    @map("target_type") @db.VarChar(30)
  targetValue Int?       @map("target_value")
  status      GoalStatus @default(active)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("group_goals")
}

model GroupMessage {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id])

  @@index([groupId, createdAt])
  @@map("group_messages")
}

// ===== Feature 1: Learning Data Prediction =====

model LearningPrediction {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  type        PredictionType
  horizonDays Int            @map("horizon_days")
  predictions Json
  modelParams Json?          @map("model_params")
  aiComment   String?        @map("ai_comment")
  createdAt   DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
  @@map("learning_predictions")
}

model LearningAlert {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  severity    AlertSeverity
  alertType   String        @map("alert_type") @db.VarChar(50)
  title       String        @db.VarChar(200)
  description String        @default("")
  dismissed   Boolean       @default(false)
  triggerData Json?         @map("trigger_data")
  createdAt   DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, dismissed])
  @@map("learning_alerts")
}

// ===== Feature 2: Smart Learning Path Planning =====

model StudyHabitProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  bestHours            Int[]    @map("best_hours")
  bestDaysOfWeek       Int[]    @map("best_days_of_week")
  avgSessionMinutes    Int      @map("avg_session_minutes")
  preferredFrequency   Int      @map("preferred_frequency")
  peakProductivityHour Int      @map("peak_productivity_hour")
  weeklyStudyMinutes   Int      @default(0) @map("weekly_study_minutes")
  analysisData         Json?    @map("analysis_data")
  lastUpdated          DateTime @default(now()) @map("last_updated")

  user User @relation(fields: [userId], references: [id])

  @@map("study_habit_profiles")
}

model SmartSchedule {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  weekStart    DateTime        @map("week_start") @db.Date
  status       SmartPlanStatus @default(draft)
  scheduleData Json            @map("schedule_data")
  adjustments  Json?
  aiExplanation String?        @map("ai_explanation")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("smart_schedules")
}

// ===== Feature 3: Multi-device Sync =====

model SyncLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  deviceId   String   @map("device_id") @db.VarChar(100)
  syncType   String   @map("sync_type") @db.VarChar(20)
  entityType String   @map("entity_type") @db.VarChar(30)
  entityId   String   @map("entity_id")
  payload    Json
  syncedAt   DateTime @default(now()) @map("synced_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, deviceId])
  @@index([userId, syncedAt])
  @@map("sync_logs")
}

model OfflineQueue {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  deviceId     String    @map("device_id") @db.VarChar(100)
  action       String    @db.VarChar(20)
  entityType   String    @map("entity_type") @db.VarChar(30)
  entityId     String?   @map("entity_id")
  payload      Json
  status       String    @default("pending") @db.VarChar(20)
  conflictData Json?     @map("conflict_data")
  createdAt    DateTime  @default(now()) @map("created_at")
  processedAt  DateTime? @map("processed_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@map("offline_queue")
}

// ===== Feature 4: Learning Partner Matching =====

model PartnerProfile {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  isSearching      Boolean  @default(true) @map("is_searching")
  bio              String   @default("") @db.VarChar(500)
  studyPreferences Json?    @map("study_preferences")
  courseIds         String[] @map("course_ids")
  goalKeywords     String[] @map("goal_keywords")
  availableHours   Int[]    @map("available_hours")
  lastActive       DateTime @default(now()) @map("last_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([isSearching])
  @@map("partner_profiles")
}

model PartnerRequest {
  id         String               @id @default(uuid())
  fromUserId String               @map("from_user_id")
  toUserId   String               @map("to_user_id")
  status     PartnerRequestStatus @default(pending)
  message    String?              @db.VarChar(300)
  score      Float                @default(0)
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  fromUser User @relation("SentRequests", fields: [fromUserId], references: [id])
  toUser   User @relation("ReceivedRequests", fields: [toUserId], references: [id])

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
  @@map("partner_requests")
}

model Partnership {
  id        String   @id @default(uuid())
  user1Id   String   @map("user1_id")
  user2Id   String   @map("user2_id")
  isActive  Boolean  @default(true) @map("is_active")
  startedAt DateTime @default(now()) @map("started_at")

  user1 User @relation("Partnerships1", fields: [user1Id], references: [id])
  user2 User @relation("Partnerships2", fields: [user2Id], references: [id])

  @@unique([user1Id, user2Id])
  @@index([user1Id, isActive])
  @@index([user2Id, isActive])
  @@map("partnerships")
}
